{
	"name": "comapeo-headless",
	"version": "0.1.0",
	"private": true,
	"description": "Headless CoMapeo daemon for Pi-class devices",
	"type": "module",
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.0.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "~24.13.0",
			"onFail": "warn"
		}
	},
	"scripts": {
		"start": "node --import tsx/esm src/daemon/index.ts",
		"start:prod": "node dist/daemon/index.js",
		"start:smoke": "node --import tsx/esm scripts/smoke.ts",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@comapeo/core": "5.5.0",
		"@comapeo/default-categories": "1.0.1",
		"@homebridge/ciao": "1.3.5",
		"debug": "4.4.3",
		"fastify": "4.29.1",
		"sodium-native": "4.3.3",
		"valibot": "1.2.0"
	},
	"devDependencies": {
		"@types/debug": "4.1.12",
		"@types/node": "24.10.13",
		"tsx": "4.19.3",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	},
	"overrides": {
		"better-sqlite3": "12.6.2"
	}
}
