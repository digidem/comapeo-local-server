# Required
COMAPEO_DEVICE_NAME=my-pi-device

# Optional (defaults shown)
COMAPEO_DATA_DIR=/data
COMAPEO_AUTO_ACCEPT_INVITES=true
COMAPEO_DEVICE_TYPE=desktop
LOG_LEVEL=info

# Optional (leave blank to omit)
# COMAPEO_ROOT_KEY=<32-hex-char root key override>
# ONLINE_STYLE_URL=https://example.com/style.json
